<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="16dp">

    <!-- Header Card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_card"
        android:padding="20dp"
        android:elevation="8dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Card Generator"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnAutoFill"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="AutoFill"
            android:textColor="@color/white"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_accent"
            android:paddingHorizontal="20dp"
            android:elevation="4dp" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Generator Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="24dp"
                android:elevation="8dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Network"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <Spinner
                            android:id="@+id/spinnerNetwork"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input"
                            android:popupBackground="@color/bg_card_solid"
                            android:elevation="2dp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Count"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp" />

                        <EditText
                            android:id="@+id/etCount"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_input_focused"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_hint"
                            android:hint="10"
                            android:textSize="15sp"
                            android:inputType="number"
                            android:gravity="center"
                            android:elevation="2dp" />
                    </LinearLayout>
                </LinearLayout>

                <Button
                    android:id="@+id/btnGenerate"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="Generate"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textAllCaps="false"
                    android:textStyle="bold"
                    android:background="@drawable/bg_button_accent"
                    android:elevation="4dp" />
            </LinearLayout>

            <!-- Results -->
            <TextView
                android:id="@+id/tvResultCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Results"
                android:textColor="@color/text_muted"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:paddingHorizontal="8dp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerResults"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:layout_marginBottom="16dp" />

            <!-- Template Section -->
            <LinearLayout
                android:id="@+id/templateSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible"
                android:background="@drawable/bg_card"
                android:padding="24dp"
                android:elevation="8dp"
                android:layout_marginBottom="16dp">

                <Spinner
                    android:id="@+id/spinnerTemplates"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input"
                    android:popupBackground="@color/bg_card_solid"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp" />

                <EditText
                    android:id="@+id/etTemplateBin"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="BIN"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etTemplateExpiry"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="MM/YY"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etTemplateName"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="Holder Name"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="10dp" />

                <EditText
                    android:id="@+id/etTemplateZip"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="ZIP"
                    android:textSize="14sp"
                    android:paddingHorizontal="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp" />

                <Button
                    android:id="@+id/btnApplyTemplate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Generate from Template"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button_accent"
                    android:elevation="4dp" />
            </LinearLayout>

            <!-- Manual Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_card"
                android:padding="24dp"
                android:elevation="8dp"
                android:layout_marginBottom="32dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Manual Card"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <EditText
                    android:id="@+id/etManualCard"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="Card number"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:paddingHorizontal="20dp"
                    android:elevation="2dp"
                    android:layout_marginBottom="12dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp">

                    <EditText
                        android:id="@+id/etManualMonth"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="MM"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp"
                        android:layout_marginEnd="8dp" />

                    <EditText
                        android:id="@+id/etManualYear"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="YY"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp"
                        android:layout_marginHorizontal="8dp" />

                    <EditText
                        android:id="@+id/etManualCvv"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="CVV"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp"
                        android:layout_marginStart="8dp" />
                </LinearLayout>

                <Button
                    android:id="@+id/btnValidate"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Validate (Luhn)"
                    android:textColor="@color/accent"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button"
                    android:elevation="4dp"
                    android:layout_marginBottom="10dp" />

                <Button
                    android:id="@+id/btnCopyManual"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="Copy"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button"
                    android:elevation="4dp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
