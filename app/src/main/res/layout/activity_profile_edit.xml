<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_card"
            android:padding="20dp"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Profile"
                android:textColor="@color/text_primary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnRandomize"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Randomize"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:textAllCaps="false"
                android:background="@drawable/bg_button_accent"
                android:paddingHorizontal="24dp"
                android:elevation="4dp" />
        </LinearLayout>

        <!-- Form Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <!-- Profile Name -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile Name"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etProfileName"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_focused"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="My Profile"
                android:textSize="15sp"
                android:paddingHorizontal="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="20dp" />

            <!-- User Agent -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="User Agent"
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnRandomUA"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="Random"
                    android:textColor="@color/accent"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:background="@drawable/bg_button"
                    android:minWidth="0dp"
                    android:paddingHorizontal="16dp"
                    android:elevation="2dp" />
            </LinearLayout>

            <EditText
                android:id="@+id/etUserAgent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="52dp"
                android:background="@drawable/bg_input_focused"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="Mozilla/5.0..."
                android:textSize="13sp"
                android:paddingHorizontal="20dp"
                android:paddingVertical="14dp"
                android:gravity="top"
                android:elevation="2dp"
                android:layout_marginBottom="20dp" />

            <!-- Homepage -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Homepage"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etHomepage"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_focused"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="https://google.com"
                android:textSize="15sp"
                android:inputType="textUri"
                android:paddingHorizontal="20dp"
                android:elevation="2dp" />
        </LinearLayout>

        <!-- Settings Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <!-- Platform & Language -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Platform"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerPlatform"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@color/bg_card_solid"
                        android:elevation="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Language"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <Spinner
                        android:id="@+id/spinnerLanguage"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input"
                        android:popupBackground="@color/bg_card_solid"
                        android:elevation="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Screen -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Screen"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/etScreenWidth"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="1920"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:gravity="center"
                    android:elevation="2dp" />

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="52dp"
                    android:text="×"
                    android:textColor="@color/text_muted"
                    android:textSize="20sp"
                    android:gravity="center" />

                <EditText
                    android:id="@+id/etScreenHeight"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_input_focused"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_hint"
                    android:hint="1080"
                    android:textSize="15sp"
                    android:inputType="number"
                    android:gravity="center"
                    android:elevation="2dp" />
            </LinearLayout>

            <!-- Hardware -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="CPU Cores"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etCpuCores"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="8"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Memory"
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <EditText
                        android:id="@+id/etMemory"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="16"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp" />
                </LinearLayout>
            </LinearLayout>

            <!-- WebGL -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WebGL Vendor"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etWebglVendor"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_focused"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="Google Inc."
                android:textSize="15sp"
                android:paddingHorizontal="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WebGL Renderer"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/etWebglRenderer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input_focused"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:hint="ANGLE..."
                android:textSize="15sp"
                android:paddingHorizontal="20dp"
                android:elevation="2dp"
                android:layout_marginBottom="20dp" />

            <!-- Timezone -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Timezone"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <Spinner
                android:id="@+id/spinnerTimezone"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:popupBackground="@color/bg_card_solid"
                android:elevation="2dp" />
        </LinearLayout>

        <!-- Protection Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Protection"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <!-- Toggles -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="WebRTC Spoof"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switchWebRTC"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/divider" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Canvas Noise"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switchCanvas"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/divider" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Audio Noise"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switchAudio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/divider" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:elevation="2dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="AdBlock"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switchAdblock"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/divider" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="16dp"
                android:background="@drawable/bg_input"
                android:elevation="2dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Cosmetic Filter"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp" />

                <Switch
                    android:id="@+id/switchCosmeticFilter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/accent"
                    android:trackTint="@color/divider" />
            </LinearLayout>
        </LinearLayout>

        <!-- Proxy Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_card"
            android:padding="24dp"
            android:elevation="8dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Proxy"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <Spinner
                android:id="@+id/spinnerProxyType"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_input"
                android:popupBackground="@color/bg_card_solid"
                android:elevation="2dp"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:id="@+id/proxyDetailsLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="12dp">

                    <EditText
                        android:id="@+id/etProxyHost"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="2"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="Host"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:elevation="2dp"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etProxyPort"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="Port"
                        android:textSize="15sp"
                        android:inputType="number"
                        android:gravity="center"
                        android:elevation="2dp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/etProxyUser"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="Username"
                        android:textSize="15sp"
                        android:paddingHorizontal="20dp"
                        android:elevation="2dp"
                        android:layout_marginEnd="10dp" />

                    <EditText
                        android:id="@+id/etProxyPass"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_input_focused"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_hint"
                        android:hint="Password"
                        android:textSize="15sp"
                        android:inputType="textPassword"
                        android:paddingHorizontal="20dp"
                        android:elevation="2dp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Save Button -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Save Profile"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/bg_button_accent"
            android:elevation="8dp"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
