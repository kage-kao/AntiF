<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AntiF" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorSurface">@color/bg_primary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">@color/error</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="Theme.AntiF.Dialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSurface">@color/bg_card_glass</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@color/bg_card_glass</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <item name="buttonBarPositiveButtonStyle">@style/AntiF.Dialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/AntiF.Dialog.Button</item>
        <item name="buttonBarNeutralButtonStyle">@style/AntiF.Dialog.Button</item>
        <item name="shapeAppearanceOverlay">@style/DialogShape</item>
    </style>

    <style name="AntiF.Dialog.Button" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/accent</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>
    
    <style name="DialogShape">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">28dp</item>
    </style>
</resources>
